# ---------------------------------------------------------------------------
# All variables are OPTIONAL. With none set, the tool works fully:
#  - email capture runs in "stub" mode (logs to server, returns success)
#  - the "Book a call" button stays hidden
# Add what you want, when you want it. Nothing breaks if these are blank.
# ---------------------------------------------------------------------------

# Booking link for the "Book a free 15-min call" button in the Netsol AI
# help section. The button is hidden until this is set.
NEXT_PUBLIC_BOOKING_URL=https://cal.com/your-handle

# Where the "Email Hamza" button sends people. Defaults to the owner's inbox.
NEXT_PUBLIC_CONTACT_EMAIL=hamza@netsolai.cz

# --- Optional AI layer: "describe your problem" free-text field ---
# With a key, Claude reads the description, maps it to your real use cases,
# and writes a personalized message. Without a key, it falls back to keyword
# matching (still works, just shallower). Uses Claude Haiku — a few cents per
# thousand submissions. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Email capture: pick ONE provider (or neither) ---

# Option A — Resend: emails YOU whenever someone leaves their address.
# Get a key at https://resend.com (free tier). LEAD_NOTIFY_EMAIL is where the
# alert goes. LEAD_FROM_EMAIL must be a verified domain in production; the
# sandbox sender below only delivers to your own Resend account email.
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=hamza@netsolai.cz
LEAD_FROM_EMAIL=AI Use-Case Finder <onboarding@resend.dev>

# Option B — MailerLite: adds the lead to a list so your sequence fires.
# Get a key at https://mailerlite.com. Group ID is optional.
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=
